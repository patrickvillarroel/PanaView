{
  "expo": {
    "name": "PanaRoute",
    "slug": "panaroute",
    "version": "1.0.0",
    "scheme": "panaroute",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1F4E79"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.panaroute.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1F4E79"
      },
      "package": "com.panaroute.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permitir que PanaRoute acceda a tu ubicación para descubrir sitios cercanos"
        }
      ],
      "expo-secure-store",
      "expo-audio"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "panaroute"
      }
    }
  }
}
